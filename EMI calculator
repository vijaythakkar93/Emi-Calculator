<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home Loan Calculator (Repo + Spread)</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: #fff;
      display: flex;
      justify-content: center;
      padding: 40px;
    }
    .container {
      background: #1e293b;
      padding: 30px;
      border-radius: 12px;
      width: 400px;
      box-shadow: 0 0 20px rgba(0,0,0,0.3);
    }
    h2 {
      text-align: center;
      margin-bottom: 20px;
    }
    label {
      display: block;
      margin-top: 10px;
    }
    input {
      width: 100%;
      padding: 8px;
      margin-top: 5px;
      border-radius: 6px;
      border: none;
    }
    button {
      width: 100%;
      margin-top: 20px;
      padding: 10px;
      background: #22c55e;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      cursor: pointer;
    }
    .result {
      margin-top: 20px;
      background: #334155;
      padding: 15px;
      border-radius: 8px;
    }
  </style>
</head>
<body>

<div class="container">
  <h2>🏠 Loan Calculator</h2>

  <label>Loan Amount (₹)</label>
  <input type="number" id="loan" value="5000000">

  <label>Tenure (Years)</label>
  <input type="number" id="tenure" value="30">

  <label>RBI Repo Rate (%)</label>
  <input type="number" id="repo" value="6.5">

  <label>Bank Spread (%)</label>
  <input type="number" id="spread" value="1.5">

  <button onclick="calculate()">Calculate</button>

  <div class="result" id="output"></div>
</div>

<script>
function calculate() {
  let P = parseFloat(document.getElementById("loan").value);
  let years = parseFloat(document.getElementById("tenure").value);
  let repo = parseFloat(document.getElementById("repo").value);
  let spread = parseFloat(document.getElementById("spread").value);

  let totalRate = repo + spread;
  let r = totalRate / 12 / 100;
  let n = years * 12;

  let emi = (P * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
  let totalPayment = emi * n;
  let totalInterest = totalPayment - P;

  let repoRatio = repo / totalRate;
  let spreadRatio = spread / totalRate;

  let repoInterest = totalInterest * repoRatio;
  let spreadInterest = totalInterest * spreadRatio;

  document.getElementById("output").innerHTML = `
    <p><b>Total Interest Rate:</b> ${totalRate.toFixed(2)}%</p>
    <p><b>EMI:</b> ₹${emi.toFixed(0)}</p>
    <p><b>Total Payment:</b> ₹${totalPayment.toFixed(0)}</p>
    <p><b>Total Interest:</b> ₹${totalInterest.toFixed(0)}</p>
    <hr>
    <p><b>Repo Interest:</b> ₹${repoInterest.toFixed(0)}</p>
    <p><b>Bank Spread Interest:</b> ₹${spreadInterest.toFixed(0)}</p>
  `;
}
</script>

</body>
</html>
